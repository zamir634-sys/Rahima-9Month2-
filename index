<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pregnancy Tracker - Pro Edition</title>
    <style>
        :root {
            --primary-color: #ff85a2;
            --soft-blue: #a2d2ff;
            --bg-color: #2c2c2e; 
            --container-bg: #ffffff;
            --input-bg: #fdf2f5;
            --card-past: #fff0f3;
            --card-rem: #eafff2;
            --clock-border: rgba(255, 255, 255, 0.4);
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            color: #333;
        }

        .container {
            background: var(--container-bg);
            padding: 15px; /* Reduced for better fit */
            border-radius: 28px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            width: 92%;
            max-width: 380px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .settings-btn {
            position: absolute;
            top: 15px;
            right: 18px;
            font-size: 1.3rem;
            cursor: pointer;
            z-index: 10;
            opacity: 0.7;
        }

        h2 { color: var(--primary-color); margin: 5px 0 2px 0; font-size: 1.3rem; transition: color 0.3s; }
        
        #father-name-display {
            font-size: 0.8rem;
            color: #666;
            margin-bottom: 8px;
            font-weight: 500;
            display: none;
        }

        #settings-panel {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #fff;
            z-index: 20;
            display: none;
            padding: 20px;
            box-sizing: border-box;
            flex-direction: column;
            text-align: left;
            overflow-y: auto;
        }

        .settings-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .setting-section-title {
            font-size: 0.7rem;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 10px;
            display: block;
        }

        .setting-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 12px 0;
        }

        .setting-item label { font-size: 0.85rem; color: #444; margin: 0; font-weight: 500;}

        .nickname-input {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #eee;
            border-radius: 10px;
            font-size: 0.9rem;
            box-sizing: border-box;
        }

        .settings-area {
            background: var(--input-bg);
            padding: 10px;
            border-radius: 18px;
            margin-bottom: 12px;
            border: 1.5px solid var(--primary-color);
            transition: all 0.3s ease;
        }

        .input-row { display: flex; gap: 8px; margin-bottom: 8px; align-items: flex-end; }
        .input-group { flex: 1; text-align: left; }
        .edit-box-wrapper { width: 55px; text-align: left; }

        label {
            font-size: 0.6rem;
            font-weight: 700;
            color: var(--primary-color);
            display: block;
            margin-bottom: 3px;
        }

        input[type="date"], input[type="number"] {
            width: 100%;
            padding: 6px 5px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.75rem;
            color: #444;
            outline: none;
            box-sizing: border-box;
            background-color: #fff;
            min-height: 32px;
        }

        .today-box {
            background: linear-gradient(135deg, #a2d2ff, #7ab6ff);
            padding: 12px;
            border-radius: 24px;
            color: white;
            margin-bottom: 15px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.05), 0 10px 20px rgba(122, 182, 255, 0.3);
        }

        .date-display { 
            font-weight: 700; 
            font-size: 0.85rem; 
            background: rgba(255,255,255,0.2); 
            padding: 3px 10px; 
            border-radius: 20px;
            backdrop-filter: blur(5px);
        }

        .analog-clock {
            width: 130px; /* Reduced from 150px to save space */
            height: 130px;
            border: 5px solid var(--clock-border);
            border-radius: 50%;
            position: relative;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(8px);
        }

        .clock-dot {
            position: absolute;
            width: 100%; height: 100%;
            text-align: center;
        }
        .clock-dot::before {
            content: ""; display: inline-block;
            width: 1.5px; height: 5px;
            background: rgba(255,255,255,0.4);
            margin-top: 1px;
        }
        .clock-dot.hour-mark::before {
            width: 2.5px; height: 8px;
            background: #fff;
        }
        
        .clock-number {
            position: absolute;
            width: 100%; height: 100%;
            text-align: center;
            font-size: 0.75rem; 
            font-weight: 700;
            padding: 14px;
            box-sizing: border-box;
            z-index: 2;
            color: white;
        }

        .analog-clock .hand {
            position: absolute;
            bottom: 50%; left: 50%;
            transform-origin: bottom;
            border-radius: 10px;
            z-index: 5;
        }
        .hour-hand { width: 4px; height: 30px; background: #fff; }
        .min-hand { width: 3px; height: 45px; background: rgba(255,255,255,0.8); }
        .sec-hand { width: 1.5px; height: 52px; background: #ff4d4d !important; z-index: 7; }
        
        .center-dot {
            position: absolute;
            top: 50%; left: 50%;
            width: 8px; height: 8px;
            background: #fff; border: 2px solid #ff4d4d;
            border-radius: 50%;
            transform: translate(-50%, -50%);
            z-index: 10;
        }

        .digital-clock {
            font-size: 1.4rem;
            font-weight: 800;
            display: none;
            background: rgba(0,0,0,0.05);
            padding: 8px 15px;
            border-radius: 15px;
        }

        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .card { padding: 10px 8px; border-radius: 20px; border: 2px solid transparent; }
        .past { background: #fff5f7; border-color: #ffdae3; }
        .rem { background: #f2fff6; border-color: #d1f7e0; }
        .card b { font-size: 0.8rem; display: block; margin-bottom: 3px; }
        .label { font-size: 0.7rem; color: #666; margin-top: 5px; display: block; }
        .val { font-size: 1.4rem; font-weight: 900; color: #222; display: block; }

        .progress-container { margin-top: 15px; }
        .bar-bg { width: 100%; background: #eee; height: 12px; border-radius: 10px; overflow: hidden; }
        .bar-fill { height: 100%; background: var(--primary-color); width: 0%; transition: width 1s; }
        .perc-display { font-size: 0.85rem; font-weight: 800; color: var(--primary-color); margin-top: 5px; display: block; }

        /* Settings Toggle Switch */
        .switch { position: relative; display: inline-block; width: 38px; height: 20px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 14px; width: 14px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: var(--primary-color); }
        input:checked + .slider:before { transform: translateX(18px); }

        .btn-save { background: var(--primary-color); color: white; border: none; padding: 10px; border-radius: 14px; font-weight: bold; cursor: pointer; margin-top: 10px; width: 100%; }
        .btn-reset { background: #fff5f5; color: #ff4d4d; border: 1px solid #ffd1d1; padding: 8px; border-radius: 14px; font-size: 0.8rem; cursor: pointer; margin-top: 10px; font-weight: 600; width: 100%;}
    </style>
</head>
<body>

<div class="container">
    <div class="settings-btn" onclick="toggleSettings(true)">⚙️</div>
    
    <div id="settings-panel">
        <div class="settings-header">
            <h3 style="margin:0; color:var(--primary-color)">Settings</h3>
            <span style="cursor:pointer; font-size:1.5rem" onclick="toggleSettings(false)">&times;</span>
        </div>
        <span class="setting-section-title">Personalization</span>
        <div class="setting-item" style="flex-direction:column; align-items:flex-start;">
            <label>Baby Nickname</label>
            <input type="text" id="baby-name-input" class="nickname-input" placeholder="e.g. My Little Angel" oninput="saveSettings()">
        </div>
        <div class="setting-item" style="flex-direction:column; align-items:flex-start;">
            <label>Father's Name</label>
            <input type="text" id="father-name-input" class="nickname-input" placeholder="Enter Father's Name" oninput="saveSettings()">
        </div>
        
        <span class="setting-section-title">Show/Hide Features</span>
        <div class="setting-item">
            <label>Show Father's Name</label>
            <label class="switch">
                <input type="checkbox" id="show-father-toggle" onchange="saveSettings()">
                <span class="slider"></span>
            </label>
        </div>
        <div class="setting-item">
            <label>Enable Digital Clock</label>
            <label class="switch">
                <input type="checkbox" id="digital-clock-toggle" onchange="saveSettings()">
                <span class="slider"></span>
            </label>
        </div>
        <button class="btn-save" onclick="toggleSettings(false)">SAVE & CLOSE</button>
        <button class="btn-reset" onclick="confirmReset()">RESET ALL DATA</button>
    </div>

    <h2 id="main-title">Pregnancy Tracker 🌸</h2>
    <div id="father-name-display"></div>
    
    <div class="settings-area">
        <div class="input-row">
            <div class="input-group">
                <label>START DATE (LMP)</label>
                <input type="date" id="input-start" oninput="syncDates('start')">
            </div>
        </div>
        <div class="input-row">
            <div class="input-group">
                <label>DUE DATE (EDD)</label>
                <input type="date" id="input-due" oninput="syncDates('due')">
            </div>
            <div class="edit-box-wrapper" id="extra-box-ui">
                <label>+DAYS</label>
                <input type="number" id="extra-rem" value="0" oninput="calculate()">
            </div>
        </div>
    </div>

    <div class="today-box">
        <div class="date-display">📅 <span id="show-today">--/--/----</span></div>
        <div id="analog-ui" class="analog-clock">
            <div class="hand hour-hand" id="hour-hand"></div>
            <div class="hand min-hand" id="min-hand"></div>
            <div class="hand sec-hand" id="sec-hand"></div>
            <div class="center-dot"></div>
        </div>
        <div id="digital-ui" class="digital-clock">00:00:00 AM</div>
    </div>

    <div class="grid">
        <div class="card past">
            <b style="color: #d63384;">PAST</b>
            <span class="label">Days</span><span class="val" id="p-d">0</span>
            <span class="label">Weeks</span><span class="val" id="p-w">0</span>
            <span class="label">Months</span><span class="val" id="p-m">0</span>
        </div>
        <div class="card rem">
            <b style="color: #2d6a4f;">REMAINING</b>
            <span class="label">Days</span><span class="val" id="r-d">0</span>
            <span class="label">Weeks</span><span class="val" id="r-w">0</span>
            <span class="label">Months</span><span class="val" id="r-m">0</span>
        </div>
    </div>

    <div class="progress-container">
        <div class="bar-bg"><div class="bar-fill" id="bar"></div></div>
        <span class="perc-display" id="perc-val">0% Completed</span>
    </div>
</div>

<script>
    window.onload = function() {
        createClockMarkers();
        document.getElementById('input-start').value = localStorage.getItem('pregStart') || "2025-08-18";
        document.getElementById('input-due').value = localStorage.getItem('pregDue') || "2026-05-31";
        document.getElementById('extra-rem').value = localStorage.getItem('extraRem') || "0";
        document.getElementById('baby-name-input').value = localStorage.getItem('babyName') || "";
        document.getElementById('father-name-input').value = localStorage.getItem('fatherName') || "";
        document.getElementById('show-father-toggle').checked = localStorage.getItem('showFather') === 'true';
        document.getElementById('digital-clock-toggle').checked = localStorage.getItem('isDigital') === 'true';
        applySettingsUI();
        calculate();
        startClock();
    };

    function createClockMarkers() {
        const clock = document.getElementById('analog-ui');
        for (let i = 0; i < 60; i++) {
            const dot = document.createElement('div');
            dot.className = 'clock-dot' + (i % 5 === 0 ? ' hour-mark' : '');
            dot.style.transform = `rotate(${i * 6}deg)`;
            clock.appendChild(dot);
        }
        for (let i = 1; i <= 12; i++) {
            const numDiv = document.createElement('div');
            numDiv.className = 'clock-number';
            numDiv.style.transform = `rotate(${i * 30}deg)`;
            numDiv.innerHTML = `<span style="display:inline-block; transform:rotate(-${i * 30}deg)">${i}</span>`;
            clock.appendChild(numDiv);
        }
    }

    function startClock() {
        setInterval(() => {
            const now = new Date();
            let h = now.getHours(), m = now.getMinutes(), s = now.getSeconds();
            const ampm = h >= 12 ? 'PM' : 'AM';
            let dh = h % 12 || 12;
            document.getElementById('digital-ui').innerText = `${dh}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')} ${ampm}`;
            document.getElementById('sec-hand').style.transform = `translateX(-50%) rotate(${s * 6}deg)`;
            document.getElementById('min-hand').style.transform = `translateX(-50%) rotate(${m * 6 + s * 0.1}deg)`;
            document.getElementById('hour-hand').style.transform = `translateX(-50%) rotate(${(h % 12) * 30 + m/2}deg)`;
        }, 1000);
    }

    function toggleSettings(show) { document.getElementById('settings-panel').style.display = show ? 'flex' : 'none'; }

    function saveSettings() {
        localStorage.setItem('babyName', document.getElementById('baby-name-input').value);
        localStorage.setItem('fatherName', document.getElementById('father-name-input').value);
        localStorage.setItem('showFather', document.getElementById('show-father-toggle').checked);
        localStorage.setItem('isDigital', document.getElementById('digital-clock-toggle').checked);
        applySettingsUI();
    }

    function applySettingsUI() {
        const isDigital = document.getElementById('digital-clock-toggle').checked;
        document.getElementById('digital-ui').style.display = isDigital ? 'block' : 'none';
        document.getElementById('analog-ui').style.display = isDigital ? 'none' : 'block';
        
        const bName = document.getElementById('baby-name-input').value;
        document.getElementById('main-title').innerText = bName ? bName + " 🌸" : "Pregnancy Tracker 🌸";
        
        const fName = document.getElementById('father-name-input').value;
        const showF = document.getElementById('show-father-toggle').checked;
        const fDisplay = document.getElementById('father-name-display');
        fDisplay.innerText = fName ? "Father: " + fName : "";
        fDisplay.style.display = (showF && fName) ? "block" : "none";
    }

    function syncDates(type) {
        const sInput = document.getElementById('input-start'), dInput = document.getElementById('input-due');
        if(type==='start') { let d = new Date(sInput.value); d.setDate(d.getDate()+280); dInput.value = d.toISOString().split('T')[0]; }
        calculate();
    }

    function calculate() {
        const startVal = document.getElementById('input-start').value;
        const dueVal = document.getElementById('input-due').value;
        const ex = parseInt(document.getElementById('extra-rem').value) || 0;
        if(!startVal || !dueVal) return;
        const start = new Date(startVal), due = new Date(dueVal);
        due.setDate(due.getDate() + ex);
        const today = new Date(); today.setHours(0,0,0,0);
        document.getElementById('show-today').innerText = today.toLocaleDateString('en-GB');
        const diffP = today - start, diffR = due - today, total = due - start;
        const getD = (ms) => Math.max(0, Math.floor(ms/86400000));
        const getW = (ms) => Math.max(0, (ms/604800000).toFixed(1));
        const getM = (ms) => Math.max(0, (ms/2629746000).toFixed(1));
        document.getElementById('p-d').innerText = getD(diffP);
        document.getElementById('p-w').innerText = getW(diffP);
        document.getElementById('p-m').innerText = getM(diffP);
        document.getElementById('r-d').innerText = getD(diffR);
        document.getElementById('r-w').innerText = getW(diffR);
        document.getElementById('r-m').innerText = getM(diffR);
        let prog = Math.min(Math.max((diffP/total)*100, 0), 100);
        document.getElementById('bar').style.width = prog + "%";
        document.getElementById('perc-val').innerText = prog.toFixed(1) + "% Completed";
        localStorage.setItem('pregStart', startVal); localStorage.setItem('pregDue', dueVal); localStorage.setItem('extraRem', ex);
    }

    function confirmReset() { if(confirm("Reset all data?")) { localStorage.clear(); location.reload(); } }
</script>
</body>
</html>
